{
  "name": "site-academico-flavio-seixas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "npm run validate:content && ASTRO_TELEMETRY_DISABLED=1 astro build && pagefind --site dist && node --import tsx scripts/generate-ics.ts",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "format": "prettier --write 'src/**/*.{astro,ts,md,css}' 'scripts/**/*.ts' 'tests/**/*.ts' '*.{ts,mjs,json,md}' '.github/**/*.yml'",
    "format:check": "prettier --check 'src/**/*.{astro,ts,md,css}' 'scripts/**/*.ts' 'tests/**/*.ts' '*.{ts,mjs,json,md}' '.github/**/*.yml'"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/sitemap": "^3.4.0",
    "astro": "^5.12.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.54.0",
    "@types/node": "^24.0.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.6.0",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.0"
  }
}
