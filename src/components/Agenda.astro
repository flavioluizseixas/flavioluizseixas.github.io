---
import { eventSlug, formatDate, withBase, todayInSaoPaulo } from '../lib/site';
const { events, title = 'Calendário completo' } = Astro.props;
const today = todayInSaoPaulo();
const types: string[] = [
  ...new Set<string>(events.map((e: any) => String(e.type)))
];
const labels: any = {
  aula: 'Aula',
  laboratorio: 'Laboratório',
  atividade: 'Atividade',
  avaliacao: 'Avaliação',
  entrega: 'Entrega',
  apresentacao: 'Apresentação',
  feriado: 'Feriado',
  'sem-aula': 'Sem aula'
};
const next = events.find(
  (e: any) => e.date >= today && !['cancelled', 'completed'].includes(e.status)
);
const moduleLabel = (note?: string) =>
  note?.match(/^Módulo\s+\d+\s*[—–-]\s*.+$/i)?.[0] ?? null;
let previousModule: string | null = null;
type AgendaItem = {
  event: any;
  module: string | null;
  startsModule: boolean;
};
const agendaItems: AgendaItem[] = events.map((event: any) => {
  const module = moduleLabel(event.note);
  const startsModule = Boolean(module && module !== previousModule);
  if (module) previousModule = module;
  return { event, module, startsModule };
});
---

<section id="calendario" aria-labelledby="calendar-title">
  <div class="section-head">
    <div>
      <span class="eyebrow">Agenda</span><h2 id="calendar-title">{title}</h2>
    </div><a href={withBase('feed/calendario.ics')}>Baixar calendário (.ics)</a>
  </div>
  <div class="calendar-controls">
    <div class="chips" aria-label="Filtrar calendário">
      <button class="chip" data-filter="all" aria-pressed="true">Todos</button>{
        types.map((type) => (
          <button class="chip" data-filter={type} aria-pressed="false">
            {labels[type]}
          </button>
        ))
      }
    </div>{
      next && (
        <a
          class="button secondary"
          href={`#${eventSlug(next.date, next.title)}`}
        >
          Ir para a próxima
        </a>
      )
    }
  </div>
  <ol class="agenda">
    {
      agendaItems.map(({ event, module, startsModule }) => (
        <>
          {startsModule && (
            <li class="agenda-module" data-module-heading={module}>
              <span>{module}</span>
            </li>
          )}
          <li
            class:list={['event', event.status]}
            data-type={event.type}
            data-module={module || undefined}
            id={eventSlug(event.date, event.title)}
          >
            <time class="event-date" datetime={event.date}>
              {formatDate(event.date, {
                day: '2-digit',
                month: 'short',
                year: undefined
              })}
              <small>
                {formatDate(event.date, {
                  weekday: 'long',
                  day: undefined,
                  month: undefined,
                  year: undefined
                })}
              </small>
            </time>
            <div>
              <span class:list={['tag', event.type]}>{labels[event.type]}</span>
              {event.status === 'changed' && <span class="tag"> Alterado</span>}
              {event.status === 'cancelled' && (
                <span class="tag"> Cancelado</span>
              )}
            </div>
            <div>
              <h3>{event.title}</h3>
              {event.note && !module && <p>{event.note}</p>}
              {event.references?.length > 0 && (
                <p>
                  <strong>Referências:</strong> {event.references.join(' · ')}
                </p>
              )}
              {event.materials?.length > 0 && (
                <p>
                  {event.materials.map((m: any) => (
                    <a href={m.url}>{m.title}</a>
                  ))}
                </p>
              )}
            </div>
          </li>
        </>
      ))
    }
  </ol>
  {
    events.length === 0 && (
      <p class="empty">
        O calendário detalhado desta disciplina será publicado em breve.
      </p>
    )
  }
</section>
<script>
  document.querySelectorAll('[data-filter]').forEach((button) =>
    button.addEventListener('click', () => {
      const filter = (button as HTMLElement).dataset.filter;
      document
        .querySelectorAll('[data-filter]')
        .forEach((b) => b.setAttribute('aria-pressed', String(b === button)));
      document.querySelectorAll('.event').forEach((e) => {
        (e as HTMLElement).hidden =
          filter !== 'all' && (e as HTMLElement).dataset.type !== filter;
      });
      document
        .querySelectorAll<HTMLElement>('.agenda-module')
        .forEach((heading) => {
          const module = heading.dataset.moduleHeading;
          heading.hidden = ![
            ...document.querySelectorAll<HTMLElement>('.event:not([hidden])')
          ].some((event) => event.dataset.module === module);
        });
    })
  );
</script>
