---
import { getCollection } from 'astro:content';
import OfferingPage from '../../../components/OfferingPage.astro';
export async function getStaticPaths() {
  const entries = await getCollection('offerings');
  return entries.map((offering) => ({
    params: {
      slug: offering.data.slug,
      term: offering.data.term.replace('.', '-')
    },
    props: { offering }
  }));
}
const { offering } = Astro.props;
---

<OfferingPage offering={offering} />
